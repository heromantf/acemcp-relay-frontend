# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-here

# LinuxDo OAuth
AUTH_LINUXDO_ID=your-linuxdo-client-id
AUTH_LINUXDO_SECRET=your-linuxdo-client-secret

# GitHub OAuth
# Callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
# If using a GitHub App (not OAuth App), enable Account Permissions > Email Addresses: Read-Only
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret
# Minimum GitHub account age in days for new signups; invalid/unset defaults to 365; 0 disables the check
AUTH_GITHUB_MIN_ACCOUNT_AGE_DAYS=365

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-database-password
POSTGRES_DB=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
